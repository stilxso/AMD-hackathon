# ─── AirQ Backend Environment Variables ───
# Copy this file to .env and fill in your API tokens.
# All tokens are free-tier. Links below.

# WAQI (World Air Quality Index) — https://aqicn.org/data-platform/token/
WAQI_API_TOKEN=your_waqi_token_here

# OpenAQ v3 — https://explore.openaq.org/register
OPENAQ_API_KEY=your_openaq_key_here

# OpenWeatherMap — https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_key_here

# ─── Model Config ───
MODEL_PATH=../fineweights.pt
NUM_CLASSES=5

# ─── Server Config ───
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
